{
  "name": "fightplanner",
  "version": "4.0.0",
  "description": "FightPlanner 4.0 - Your Ultimate Mod Manager",
  "main": "out/main/main.js",
  "author": {
    "name": "Shattered Chaos",
    "email": "noreply@fightplanner.app"
  },
  "license": "MIT",
  "scripts": {
    "start": "npx nodemon --watch out --delay 1 --exec \"electron .\"",
    "ts:build": "tsc --build",
    "ts:watch": "tsc --build --watch",
    "dev:reload": "concurrently \"npm run ts:watch\" \"npm run start\"",
    "build:test": "npm run ts:build && electron-builder --win portable --config",
    "build:win": "npm run ts:build && electron-builder --win --config",
    "build:linux": "npm run ts:build && electron-builder --linux --config",
    "build:appimage": "npm run ts:build && electron-builder --linux AppImage --config",
    "build:all": "npm run ts:build && electron-builder -wml --config",
    "dist": "npm run ts:build && electron-builder",
    "i18n:upload": "crowdin upload sources",
    "i18n:download": "crowdin download",
    "i18n:status": "crowdin status",
    "i18n:sync": "npm run i18n:upload && npm run i18n:download"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "basic-ftp": "^5.3.1",
    "core-util-is": "^1.0.3",
    "discord-rpc": "^4.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "fast-xml-parser": "^5.7.0",
    "node-7z": "^3.0.0",
    "posthog-node": "^5.21.2",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/node-7z": "^2.1.11",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.7.0",
    "gsap": "3.12.5",
    "lottie-web": "5.12.2",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.shatteredchaos.fightplanner",
    "productName": "FightPlanner",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "FIREXDF",
        "repo": "FightPlannerBetaSourceCode"
      }
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "7z.exe",
          "7z.dll"
        ]
      },
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "7zz"
        ]
      },
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "ParamXML/**/*"
        ]
      },
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "prc2json/**/*",
          "MSBTEditorCLI/**/*"
        ]
      }
    ],
    "protocols": [
      {
        "name": "FightPlanner Protocol",
        "role": "Viewer",
        "schemes": [
          "fightplanner"
        ]
      }
    ],
    "files": [
      "out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets/app-icons",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/app-icons/icon.ico",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FightPlanner",
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/app-icons/icon.icon",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/app-icons/icon.png",
      "category": "Utility",
      "maintainer": "Shattered Chaos <noreply@fightplanner.app>"
    }
  }
}
